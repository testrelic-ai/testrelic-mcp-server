# ─── MCP Server ───────────────────────────────────────────────────────────────
# Transport: "stdio" (default, for Claude Desktop / IDE) or "http" (Phase 2, cloud)
MCP_TRANSPORT=stdio

# Port used when MCP_TRANSPORT=http
PORT=3000

# ─── Mock API Server ──────────────────────────────────────────────────────────
# All clients fall back to this URL when real API credentials are not set.
# Run `npm run mock` to start the mock server on this port.
MOCK_SERVER_URL=http://localhost:4000

# ─── Real API Overrides (leave blank to use mock) ─────────────────────────────
# TestRelic
TESTRELIC_API_BASE_URL=
TESTRELIC_API_KEY=

# Amplitude (both required for querying data — read the docs before filling these in)
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=

# Grafana Loki
LOKI_BASE_URL=
LOKI_USERNAME=
LOKI_PASSWORD=

# Jira
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

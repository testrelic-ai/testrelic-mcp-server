# =============================================================================
# Dependencies
# =============================================================================
node_modules/
jspm_packages/

# =============================================================================
# Build output
# =============================================================================
dist/
build/
build/Release

# TypeScript incremental build cache
*.tsbuildinfo

# =============================================================================
# Environment & secrets
# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep .env.example — it's a committed template

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# =============================================================================
# Runtime data
# =============================================================================
pids/
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# =============================================================================
# Testing & coverage
# =============================================================================
coverage/
*.lcov
.nyc_output/

# =============================================================================
# Package manager caches
# =============================================================================
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Optional caches
.eslintcache
.stylelintcache

# =============================================================================
# Misc build tool caches
# =============================================================================
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.cache
.parcel-cache

# =============================================================================
# Temporary files
# =============================================================================
tmp/
temp/

# =============================================================================
# OS generated files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================================================
